<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo dans card blanche -->
        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/logo_mindcheck"
                android:scaleType="centerInside"
                android:contentDescription="Logo" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Bienvenue sur"
            android:fontFamily="serif"
            android:textSize="20sp"
            android:textColor="#6B7B6B"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="MindCheck"
            android:fontFamily="serif"
            android:textStyle="bold|italic"
            android:textSize="38sp"
            android:textColor="#3D5A3D"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Prenez soin de votre esprit"
            android:textSize="16sp"
            android:textColor="#6B7B6B"
            android:gravity="center" />

        <Button
            android:id="@+id/btnStart"
            style="@style/ButtonPrimary"
            android:layout_width="220dp"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="Commencer" />

    </LinearLayout>
</RelativeLayout>
