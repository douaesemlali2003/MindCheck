<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F0E8">

    <!-- Header compact -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F0E8"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="10dp"
        android:gravity="center">

        <FrameLayout
            android:layout_width="70dp"
            android:layout_height="70dp">
            <com.example.quizapp.AvatarView
                android:id="@+id/avatarView"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Compagnon MindCheck"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#2D3B2D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Je suis là pour vous écouter"
            android:textSize="12sp"
            android:textColor="#6B7B6B" />
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8E3D9" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBarChat"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal" />

    <!-- Messages : prend tout l'espace restant -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:background="#F5F0E8" />

    <!-- Separator input -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8E3D9" />

    <!-- Input area — toujours visible en bas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <!-- Champ de saisie + micro -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/chat_input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Dis-moi tout..."
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:textColor="#2D3B2D"
                android:textColorHint="#9CA89C"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/btnMic"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/btn_icon_circle"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_baseline_mic_24"
                    app:tint="#FFFFFF"
                    android:contentDescription="Microphone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bouton envoi -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_icon_circle"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@null"
                android:src="@android:drawable/ic_menu_send"
                app:tint="#FFFFFF"
                android:contentDescription="Envoyer" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
